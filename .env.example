# =============================================================================
# AI Bug Resolver — Environment Variables
# Copy this file to `.env` and fill in real values. Never commit .env.
# =============================================================================

# --- Jira Cloud (read-only access to a single project) ---
JIRA_BASE_URL=https://your-tenant.atlassian.net
JIRA_EMAIL=bot@example.com
JIRA_API_TOKEN=replace-with-jira-api-token
JIRA_PROJECT_KEY=BUG

# --- Bitbucket Cloud (bot account with minimal permissions on test repo) ---
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_REPO_SLUG=ai-bug-resolver-test
BITBUCKET_USERNAME=bot-username
BITBUCKET_APP_PASSWORD=replace-with-bitbucket-app-password

# --- Notification webhook (Slack incoming webhook or Google Chat webhook URL) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
GOOGLE_CHAT_WEBHOOK_URL=

# --- Webhook security ---
# Random secret required as ?secret= query parameter on /webhook/jira
WEBHOOK_SECRET=replace-with-a-long-random-string

# --- OpenClaw gateway (called by the webhook handler) ---
OPENCLAW_GATEWAY_URL=http://openclaw:8080
OPENCLAW_API_KEY=replace-with-openclaw-api-key

# --- LLM used by OpenClaw (provider-dependent) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Allowlists (defaults match MVP scope; override at your own risk) ---
ALLOWED_REPO_SLUG=ai-bug-resolver-test
ALLOWED_DIRECTORY=src/allowed-folder/
PR_DESTINATION_BRANCH=develop
DEFAULT_SOURCE_BRANCH=develop

# --- Logging ---
LOG_LEVEL=INFO

# =============================================================================
# Infrastructure RCA Configuration (Use Case 2)
# Optional — only needed if you're running the Jenkins / server-checks stack.
# =============================================================================
JENKINS_URL=https://your-jenkins.example.com
JENKINS_USERNAME=your-jenkins-username
JENKINS_API_TOKEN=your-jenkins-api-token
JENKINS_WEBHOOK_SECRET=your-jenkins-webhook-secret
# Comma-separated list of hostnames the infra agent may probe over HTTP.
ALLOWED_MONITORING_DOMAINS=your-server1.example.com,your-server2.example.com
GCHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/YOUR/messages?key=YOUR_KEY&token=YOUR_TOKEN
