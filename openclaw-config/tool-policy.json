{
  "version": "1.0",
  "default": "deny",
  "shell": {
    "enabled": false
  },
  "browser": {
    "enabled": false
  },
  "filesystem": {
    "enabled": false,
    "workspace_only": true,
    "allowed_paths": []
  },
  "network": {
    "default": "deny",
    "allow": [
      "mcp-server:8000"
    ]
  },
  "skills": {
    "third_party": false,
    "allowed": []
  },
  "mcp": {
    "allow": [
      "ai-bug-resolver-mcp.jira_get_issue",
      "ai-bug-resolver-mcp.bitbucket_list_files",
      "ai-bug-resolver-mcp.bitbucket_read_file",
      "ai-bug-resolver-mcp.bitbucket_create_branch",
      "ai-bug-resolver-mcp.bitbucket_commit_file",
      "ai-bug-resolver-mcp.bitbucket_create_pr",
      "ai-bug-resolver-mcp.send_notification"
    ],
    "deny": ["*"]
  }
}
